  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/bun": "^1.3.14",
    "@types/jest": "^29",
    "@types/react": "~19.2.2",
    "@typescript-eslint/parser": "^8.62.1",
    "babel-plugin-inline-import": "^3.0.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "jest": "^29",
    "jest-expo": "^57.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "bun run start:staging",
    "start:staging": "cross-env APP_ENV=staging expo start",
    "start:prod": "cross-env APP_ENV=production expo start",
    "android": "cross-env APP_ENV=staging expo start --android",
    "android:prod": "cross-env APP_ENV=production expo start --android",
    "ios": "cross-env APP_ENV=staging expo start --ios",
    "ios:prod": "cross-env APP_ENV=production expo start --ios",
    "web": "cross-env APP_ENV=staging expo start --web",
    "db:generate": "drizzle-kit generate",
    "run:android": "cross-env APP_ENV=staging expo run:android",
    "run:ios": "cross-env APP_ENV=staging expo run:ios",
    "build:apk": "bun run ./scripts/build-apk.ts",
    "build:apk:prod": "bun run ./scripts/build-apk.ts --prod",
    "build:ios": "bun run ./scripts/build-ios.ts",
    "build:ios:prod": "bun run ./scripts/build-ios.ts --prod",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage"
  },
  "private": true
}
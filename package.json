    "expo-localization": "^56.0.6",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "i18next": "^26.3.3",
    "react": "19.2.3",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.80.0",
